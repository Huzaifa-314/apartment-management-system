PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/room-management
FRONTEND_URL=http://localhost:5173

JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=optional-same-as-jwt-if-not-using-jwt-refresh-signing

# SMTP (optional — emails are skipped if host/user not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Seed script default password for demo users
SEED_PASSWORD=password
